{
  "general": {
    "initialUrl": "https://www.mornscience.biz",
    "appName": "MornClient",
    "iosBundleId": "co.median.ios.mornclient",
    "iosVersionString": "1.0.0",
    "iosBuildNumber": 1,
    "userAgentAdd": "median",
    "publicKey": "mornclient",
    "forceUserAgent": "",
    "enableWindowOpen": true,
    "userAgentRegexes": [],
    "replaceStrings": [],
    "nativeBridgeUrls": [],
    "languages": [],
    "keepScreenOn": null,
    "iosUserAgentAdd": "median",
    "iosForceUserAgent": "",
    "iosCustomHeaders": {},
    "injectMedianJS": true,
    "forceSessionCookieExpiry": 0,
    "version": 1
  },
  "navigation": {
    "iosPullToRefresh": true,
    "iosShowOfflinePage": true,
    "iosConnectionOfflineTime": 10,
    "toolbarNavigation": {
      "enabled": false,
      "visibilityByPages": "allPages",
      "visibilityByBackButton": "backButtonActive",
      "items": []
    },
    "tabNavigation": {
      "tabSelectionConfig": [],
      "tabMenus": [],
      "active": false
    },
    "sidebarNavigation": {
      "menuSelectionConfig": {
        "redirectLocations": [
          {
            "regex": ".*",
            "menuName": "default",
            "loggedIn": true
          }
        ]
      },
      "menus": [
        {
          "active": false,
          "name": "default",
          "items": []
        }
      ]
    },
    "regexInternalExternal": {
      "rules": [
        {
          "regex": "^(?!https?://).*",
          "mode": "external",
          "label": "Non-web links"
        },
        {
          "regex": ".*\\\\.(apk|exe|dmg|pkg|deb|rpm|msi|zip|rar|7z|tar|gz)$",
          "mode": "external",
          "label": "Download files"
        },
        {
          "regex": "https?://accounts\\\\.google\\\\.com.*",
          "mode": "internal",
          "label": "Google Login"
        },
        {
          "regex": "https?://login\\\\.microsoftonline\\\\.com.*",
          "mode": "internal",
          "label": "Microsoft Login"
        },
        {
          "regex": "https?://([-\\\\w]+\\\\.)*github\\\\.com/(login|oauth).*",
          "mode": "internal",
          "label": "GitHub Login"
        },
        {
          "regex": "https?://appleid\\\\.apple\\\\.com.*",
          "mode": "internal",
          "label": "Apple Login"
        },
        {
          "regex": "https?://([-\\\\w]+\\\\.)*facebook\\\\.com.*(login|oauth|dialog).*",
          "mode": "internal",
          "label": "Facebook Login"
        },
        {
          "regex": "https?:\\/\\/([-\\\\w]+\\\\.)*mornscience\\\\.biz(\\/.*)?$",
          "mode": "internal",
          "label": "All pages on my domain"
        },
        {
          "regex": ".*",
          "mode": "appbrowser",
          "label": "All Other Links"
        }
      ],
      "active": true
    },
    "navigationLevels": {
      "active": true,
      "levels": []
    },
    "navigationTitles": {
      "active": true,
      "titles": []
    },
    "redirects": []
  },
  "styling": {
    "navigationTitleImage": false,
    "showNavigationBar": false,
    "iosDarkMode": "auto",
    "iosTintColor": "#0E0D08",
    "iosTintColorDark": "#ffffff",
    "iosTitleColor": "#0E0D08",
    "iosTitleColorDark": "#ffffff",
    "iosStatusBarBackgroundColor": "#ffffffff",
    "iosStatusBarBackgroundColorDark": "#000000",
    "iosEnableBlurInStatusBar": false,
    "iosSidebarFont": "Default",
    "iosSidebarTextColor": "#0E0D08",
    "iosSidebarTextColorDark": "#ffffff",
    "iosSidebarBackgroundColor": "#f8f8f8",
    "iosSidebarBackgroundColorDark": "#202020",
    "iosNavigationBarTintColor": "#f8f8f8",
    "iosNavigationBarTintColorDark": "#202020",
    "iosTabBarTintColor": "#f8f8f8",
    "iosTabBarTintColorDark": "#000000",
    "disableAnimations": false,
    "splashScreen": {
      "ios": {
        "backgroundColor": "#FFFFFF",
        "backgroundColorDark": "#000000",
        "animated": false
      }
    },
    "iosInitialZoom": 1,
    "iosStatusBarStyle": "auto",
    "iosEnableOverlayInStatusBar": false,
    "iosActivityIndicatorColor": "#808080",
    "iosActivityIndicatorColorDark": "#808080",
    "forceViewportWidth": null,
    "pinchToZoom": null,
    "iosDynamicType": null
  },
  "permissions": {
    "usesGeolocation": true,
    "enableWebRTCamera": true,
    "enableWebRTCMicrophone": true,
    "iosLocationUsageDescription": "This app needs access to your location to provide location-based services",
    "iosCameraUsageDescription": "This app needs access to your camera to take photos or videos",
    "iosMicrophoneUsageDescription": "This app needs access to your microphone to record audio",
    "iOSATTUserTrackingDescription": "We use your data to improve service experience",
    "iOSRequestATTConsentOnLoad": false
  },
  "developmentTools": {
    "enableWebConsoleLogs": false
  },
  "services": {},
  "security": {
    "network": {
      "allowInsecure": null
    }
  }
}
