    "regexInternalExternal": {
      "rules": [
        {
          "regex": "^(?!https?://).*",
          "mode": "external",
          "label": "Non-web links (tel:, mailto:, sms:, etc.)",
          "pagesToTrigger": "custom"
        },
        {
          "regex": ".*\\.(apk|exe|dmg|pkg|deb|rpm|msi|zip|rar|7z|tar|gz)$",
          "mode": "external",
          "label": "Download files",
          "pagesToTrigger": "custom"
        },
        {
          "regex": "https?://([-\\w]+\\.)*(alipay|alipayobjects|alipaydev)\\.com.*",
          "mode": "external",
          "label": "Alipay",
          "pagesToTrigger": "custom"
        },
        {
          "regex": "https?://open\\.weixin\\.qq\\.com.*",
          "mode": "internal",
          "label": "WeChat Login",
          "pagesToTrigger": "custom"
        },
        {
          "regex": "https?://([-\\w]+\\.)*weixin\\.qq\\.com.*|https?://wx\\.tenpay\\.com.*|weixin://.*|wxpay://.*",
          "mode": "external",
          "label": "WeChat Pay",
          "pagesToTrigger": "custom"
        },
        {
          "regex": "https?://([-\\w]+\\.)*paypal\\.com.*",
          "mode": "external",
          "label": "PayPal",
          "pagesToTrigger": "custom"
        },
        {
          "regex": "https?://accounts\\.google\\.com.*",
          "mode": "internal",
          "label": "Google Login",
          "pagesToTrigger": "custom"
        },
        {
          "regex": "https?://login\\.microsoftonline\\.com.*",
          "mode": "internal",
          "label": "Microsoft Login",
          "pagesToTrigger": "custom"
        },
        {
          "regex": "https?://([-\\w]+\\.)*github\\.com/(login|oauth).*",
          "mode": "internal",
          "label": "GitHub Login",
          "pagesToTrigger": "custom"
        },
        {
          "regex": "https?://appleid\\.apple\\.com.*",
          "mode": "internal",
          "label": "Apple Login",
          "pagesToTrigger": "custom"
        },
        {
          "regex": "https?://([-\\w]+\\.)*facebook\\.com.*(login|oauth|dialog).*",
          "mode": "internal",
          "label": "Facebook Login",
          "pagesToTrigger": "custom"
        },
        {
          "regex": "https?://([-\\w]+\\.)*facebook\\.com.*",
          "mode": "appbrowser",
          "label": "Facebook",
          "pagesToTrigger": "custom"
        },
        {
          "regex": "https?://([\\-\\w]+\\.)*(twitter|x)\\.com/.*",
          "mode": "appbrowser",
          "label": "Twitter/X",
          "pagesToTrigger": "custom"
        },
        {
          "regex": "https?://([-\\w]+\\.)*instagram\\.com/.*",
          "mode": "appbrowser",
          "label": "Instagram",
          "pagesToTrigger": "custom"
        },
        {
          "regex": "https?://([-\\w]+\\.)*linkedin\\.com/.*",
          "mode": "appbrowser",
          "label": "LinkedIn",
          "pagesToTrigger": "custom"
        },
        {
          "regex": "https?://([-\\w]+\\.)*google\\.com/maps.*|https?://maps\\.google\\.com.*",
          "mode": "appbrowser",
          "label": "Google Maps",
          "pagesToTrigger": "custom"
        },
        {
          "regex": "https?:\\/\\/([-\\w]+\\.)*mornclient\\.top(\\/.*)?$",
          "mode": "internal",
          "label": "All pages on my domain",
          "pagesToTrigger": "domain"
        },
        {
          "regex": ".*",
          "mode": "appbrowser",
          "label": "All Other Links",
          "pagesToTrigger": "all"
        }
      ],
      "active": true
    },
