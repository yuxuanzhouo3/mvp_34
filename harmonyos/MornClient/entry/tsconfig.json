{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ES2020",
    "lib": [
      "ES2021",
      "DOM"
    ],
    "declaration": true,
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": [],
    "paths": {
      "@ohos/*": [
        "./oh_modules/.ohpm/@ohos/*/src/main/ets"
      ]
    }
  },
  "include": [
    "src/**/*.ets",
    "src/**/*.ts"
  ]
}
