{
  "general": {
    "initialUrl": "https://www.mornscience.biz",
    "appName": "MornClient",
    "bundleName": "com.mornclient_harmony.app",
    "versionName": "1.0.0",
    "versionCode": 1,
    "userAgentAdd": "median",
    "injectMedianJS": true,
    "forceSessionCookieExpiry": 0
  },
  "navigation": {
    "pullToRefresh": true,
    "showOfflinePage": true,
    "connectionOfflineTime": 10,
    "regexInternalExternal": {
      "rules": [
        {
          "regex": "^(?!https?://).*",
          "mode": "external",
          "label": "Non-web links"
        },
        {
          "regex": "https?://accounts\\\\.google\\\\.com.*",
          "mode": "internal",
          "label": "Google Login"
        },
        {
          "regex": "https?://appleid\\\\.apple\\\\.com.*",
          "mode": "internal",
          "label": "Apple Login"
        },
        {
          "regex": "https?://([-\\\\w]+\\\\.)*github\\\\.com/(login|oauth).*",
          "mode": "internal",
          "label": "GitHub Login"
        },
        {
          "regex": "https?:\\/\\/([-\\\\w]+\\\\.)*mornscience\\\\.biz(\\/.*)?$",
          "mode": "internal",
          "label": "All pages on my domain"
        },
        {
          "regex": ".*",
          "mode": "appbrowser",
          "label": "All Other Links"
        }
      ],
      "active": true
    }
  },
  "styling": {
    "backgroundColor": "#FFFFFF",
    "backgroundColorDark": "#000000",
    "statusBarColor": "#FFFFFF",
    "statusBarColorDark": "#000000"
  },
  "permissions": {
    "usesGeolocation": true,
    "enableCamera": true,
    "enableMicrophone": true
  },
  "services": {},
  "security": {
    "network": {
      "allowInsecure": null
    }
  }
}
