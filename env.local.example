# =========================
# Local development env file
# Copy this file to `.env.local` (DO NOT commit `.env.local`)
# =========================

# -------------------------
# App base URL (required)
# -------------------------
# 本地开发：
#   - 普通开发：http://localhost:3000
#   - 微信登录测试（需要内网穿透）：https://your-domain.ngrok-free.app
#     配置步骤：见 WECHAT_OAUTH_SETUP.md
#     注意：微信登录要求公网域名，不能使用 localhost
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Used by invite/share redirects and some server-side URL generation
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -------------------------
# 国内/国际版(zh/en)切换
# -------------------------
# zh = 国内版（CloudBase/微信登录/支付宝/微信支付）
# en = 国际版（Supabase/Stripe/PayPal）
NEXT_PUBLIC_DEFAULT_LANGUAGE=zh

# -------------------------
# Geo / IP detection (optional)
# -------------------------
# IP 地理检测 API
IP_API_URL=https://ipapi.co/json/
# 生产环境务必改为 true，确保“检测失败即拦截”
GEO_FAIL_CLOSED=false

# -------------------------
# Admin system (required for /admin)
# -------------------------
# 生产环境必须配置强随机值
ADMIN_SESSION_SECRET=CHANGE_ME

# -------------------------
# Market 控制端（/market）管理员登录
# -------------------------
# 说明：
# - 这里不要填写真实密码（因为这个文件通常会被提交到 git）
# - 真实账号密码请写到你本机的 `.env.local`（已在 .gitignore 里，不会提交）
# - 部署到线上时，请在部署平台的环境变量里配置，并设置强随机的 JWT secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME
MARKET_ADMIN_JWT_SECRET=CHANGE_ME

# -------------------------
# JWT (required for some domestic APIs / token issuance)
# -------------------------
JWT_SECRET=CHANGE_ME

# -------------------------
# CloudBase 配置（国内版必填）
# -------------------------
# 顶部栏项目名称 -> 环境ID
WECHAT_CLOUDBASE_ID=CHANGE_ME
# 头像 -> 账号信息 -> 访问管理 -> 访问秘钥 -> API密钥管理 -> 密钥
CLOUDBASE_SECRET_ID=CHANGE_ME
CLOUDBASE_SECRET_KEY=CHANGE_ME
# 可选：不填会按 envId 自动拼默认 bucketId
CLOUDBASE_BUCKET_ID=

# -------------------------
# 微信 OAuth 配置（国内版 - PC 扫码）
# -------------------------
# 重要：微信登录需要公网域名，本地开发请使用 ngrok 等内网穿透工具
# 配置步骤：见 WECHAT_OAUTH_SETUP.md
# 在微信开放平台配置回调域名时，只填域名部分（不含 https:// 和路径）
# 例如：your-domain.ngrok-free.app
WECHAT_APP_ID=CHANGE_ME
WECHAT_APP_SECRET=CHANGE_ME

# 安卓微信登录配置（国内版）
WECHAT_APP_ANDROID_ID=
WECHAT_APP_ANDROID_SECRET=

# 微信小程序登录配置（国内版）
WX_MINI_APPID=CHANGE_ME
WX_MINI_SECRET=CHANGE_ME

# -------------------------
# 微信支付（国内版可选，开启订阅支付需要）
# -------------------------
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
# PEM 私钥内容（建议用部署平台的 secret 管理；本地可放 .env.local）
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_SERIAL_NO=

# -------------------------
# 支付宝（国内版可选，开启订阅支付需要）
# -------------------------
ALIPAY_APP_ID=
# 应用私钥（PKCS8）
ALIPAY_PRIVATE_KEY=
# 支付宝公钥
ALIPAY_ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
# page | wap
ALIPAY_PRODUCT_MODE=page
# true=沙箱
ALIPAY_SANDBOX=true

# -------------------------
# Supabase（国际版必填）
# -------------------------
# From Supabase Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# 兼容别名（可选）：有些平台会用 publishable_key 命名
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-side only
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# -------------------------
# Stripe（国际版支付，可选）
# -------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# -------------------------
# PayPal（国际版支付，可选）
# -------------------------
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# sandbox | production
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_WEBHOOK_ID=
# 仅开发环境可设 true，生产环境必须为 false
PAYPAL_SKIP_SIGNATURE_VERIFICATION=true

# -------------------------
# GitHub 构建（可选：安卓构建/工作流）
# -------------------------
GITHUB_OWNER=
GITHUB_APK_REPO=
GITHUB_TOKEN=

# -------------------------
# 邮件 SMTP（可选：邮件登录/通知）
# -------------------------
AUTH_EMAIL_SMTP_HOST=
AUTH_EMAIL_SMTP_PORT=465
AUTH_EMAIL_SMTP_USER=
AUTH_EMAIL_SMTP_PASS=
AUTH_EMAIL_FROM=


